                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status code is 200', function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test('name matches created data', function () {",
                      "    var json = pm.response.json();",
                      "    pm.expect(json.name).to.equal('E2E Test User');",
                      "});",
