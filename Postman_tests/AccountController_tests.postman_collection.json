                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/abc",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "abc"]
            }
          }
        }
