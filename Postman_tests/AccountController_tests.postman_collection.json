                  "    pm.expect(id).to.be.above(0);",
                  "});",
                  "",
                  "// Сохраняем ID для следующих запросов",
                  "var createdId = pm.response.text().trim();",
                  "pm.collectionVariables.set('accountId', createdId);",
                  "console.log('Created account ID:', createdId);",
                  "",
                  "pm.test('Response time is less than 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
