    {
      "name": "4. Get All Accounts — GET /accounts",
      "item": [
        {
          "name": "GET /accounts — 200 OK (список аккаунтов)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Array is not empty (после создания аккаунтов)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Each element has required fields', function () {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(account) {",
                  "        pm.expect(account).to.have.property('accountId');",
                  "        pm.expect(account).to.have.property('name');",
                  "        pm.expect(account).to.have.property('email');",
                  "        pm.expect(account).to.have.property('bill');",
                  "    });",
                  "});",
                  "",
                  "pm.test('accountId is a positive number in each element', function () {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(account) {",
                  "        pm.expect(account.accountId).to.be.a('number').and.above(0);",
                  "    });",
                  "});",
                  "",
                  "pm.test('Response time is less than 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["accounts"]
            }
          }
        }
      ]
