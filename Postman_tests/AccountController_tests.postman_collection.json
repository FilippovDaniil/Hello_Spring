    {
      "name": "3. Get Account by ID — GET /accounts/{id}",
      "item": [
        {
          "name": "GET /accounts/{id} — 200 OK (существующий ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has required fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('accountId');",
                  "    pm.expect(json).to.have.property('name');",
                  "    pm.expect(json).to.have.property('email');",
                  "    pm.expect(json).to.have.property('bill');",
                  "});",
                  "",
                  "pm.test('accountId matches requested ID', function () {",
                  "    var json = pm.response.json();",
                  "    var requestedId = parseInt(pm.collectionVariables.get('accountId'));",
                  "    pm.expect(json.accountId).to.equal(requestedId);",
                  "});",
                  "",
                  "pm.test('name is a non-empty string', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('email is a non-empty string', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.email).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Response time is less than 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/{{accountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "{{accountId}}"]
            }
          }
        },
        {
          "name": "GET /accounts/{id} — 404 Not Found (несуществующий ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 or 500 (account not found)', function () {",
                  "    // Spring по умолчанию возвращает 500 для необработанных RuntimeException,",
                  "    // если не добавлен @ControllerAdvice. Принимаем оба варианта.",
                  "    pm.expect(pm.response.code).to.be.oneOf([404, 500]);",
                  "});",
                  "",
                  "pm.test('Response is not an account object', function () {",
                  "    try {",
                  "        var json = pm.response.json();",
                  "        // Если JSON — убеждаемся, что это не полноценный account",
                  "        pm.expect(json).to.not.have.all.keys('accountId', 'name', 'email', 'bill');",
                  "    } catch(e) {",
                  "        // Ответ не является JSON — это тоже приемлемо для ошибки",
                  "        pm.expect(pm.response.text()).to.not.be.empty;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/accounts/99999",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "99999"]
            }
          }
        },
        {
          "name": "GET /accounts/{id} — 400/500 (строка вместо ID)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 4xx or 5xx for invalid path variable', function () {",
